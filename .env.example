# Email provider selection: resend | smtp | console | auto (default: auto → Resend first, then SMTP)
EMAIL_PROVIDER=resend
# Default sender used by any provider (Resend requires a verified domain; use a verified address).
EMAIL_FROM=Bin Askar Technology <abdullah@binaskar.org>

# Resend (HTTPS API — works on Render Free where SMTP ports are blocked)
RESEND_API_KEY=re_xxxxxxxx
# Optional: overrides EMAIL_FROM for Resend only
RESEND_FROM=Bin Askar Technology <abdullah@binaskar.org>

# PrivateEmail SMTP (only reachable on hosts that allow outbound SMTP, e.g. a paid Render plan)
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=abdullah@binaskar.org
SMTP_PASS=your-privateemail-mailbox-password
SMTP_FROM_NAME=Bin Askar Technology

# Where contact form messages are delivered
CONTACT_EMAIL=abdullah@binaskar.org

# Public site URL (SEO, canonical)
NEXT_PUBLIC_SITE_URL=https://binaskar.org
