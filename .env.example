# PrivateEmail SMTP (use this when the Render service is on a paid plan)
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=abdullah@binaskar.org
SMTP_PASS=your-privateemail-mailbox-password
SMTP_FROM_NAME=Bin Askar Technology

# Where contact form messages are delivered
CONTACT_EMAIL=abdullah@binaskar.org

# Optional HTTPS fallback when using Render Free (SMTP ports are blocked there)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=Bin Askar Technology <abdullah@binaskar.org>

# Public site URL (SEO, canonical)
NEXT_PUBLIC_SITE_URL=https://binaskar.org
